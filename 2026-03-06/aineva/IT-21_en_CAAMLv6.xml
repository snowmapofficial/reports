    <avalancheProblem>
      <problemType>gliding_snow</problemType>
      <elevation uom="m">
        <lowerBound>1600</lowerBound>
      </elevation>
      <aspect>SE</aspect>
      <aspect>W</aspect>
      <aspect>E</aspect>
      <aspect>S</aspect>
